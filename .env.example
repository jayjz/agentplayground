# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database - PostgreSQL
POSTGRES_USER=agentplayground
POSTGRES_PASSWORD=agentplayground_dev_password
POSTGRES_DB=agentplayground
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# PostgreSQL with pgvector
POSTGRES_VECTOR_DB=agentplayground_vectors

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
REDIS_CACHE_DB=1

# DuckDB
DUCKDB_PATH=./data/analytics.duckdb

# LiteLLM / Model Providers
# Set at least one provider key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# LiteLLM Configuration
LITELLM_MODEL=gpt-4o-mini
LITELLM_TEMPERATURE=0.1
LITELLM_MAX_TOKENS=4000

# Prefect
PREFECT_API_URL=http://localhost:4200/api
PREFECT_UI_URL=http://localhost:4200

# Market Data Providers (Paper Trading Only)
# Alpha Vantage
ALPHA_VANTAGE_API_KEY=

# FRED
FRED_API_KEY=

# News API
NEWS_API_KEY=

# SEC EDGAR
SEC_USER_AGENT=AgentPlayground/1.0 (contact@example.com)

# Paper Trading
PAPER_TRADING_ENABLED=true
PAPER_TRADING_INITIAL_BALANCE=1000000
PAPER_TRADING_BROKER=mock

# Live Trading - KEEP DISABLED
LIVE_TRADING_ENABLED=false
# BROKER_API_KEY=
# BROKER_API_SECRET=

# OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=agentplayground-api

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
